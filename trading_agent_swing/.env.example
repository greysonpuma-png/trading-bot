# Copy this to .env and fill in. Never commit .env.

# === Alpaca — get keys at https://alpaca.markets ===
# Start with PAPER keys. Only change to live keys after months of paper trading.
ALPACA_API_KEY=your_paper_api_key
ALPACA_SECRET_KEY=your_paper_secret_key
ALPACA_PAPER=true

# === Ollama (local) ===
OLLAMA_HOST=http://localhost:11434
# Model recommendations (pick based on your RAM):
#   16GB Mac: llama3.1:8b   or  qwen3:8b
#   32GB Mac: qwen3:14b     or  mistral-small3:24b
#   64GB+ :   qwen3:32b     or  llama3.3:70b-instruct-q4_K_M
MODEL_NAME=qwen3:14b
